# Newman runtime configuration
# Copy this file to `.env` and adjust values as needed.

# Server
NEWMAN_SERVER_HOST=0.0.0.0
NEWMAN_SERVER_PORT=8000

# Provider
NEWMAN_PROVIDER_TYPE=openai_compatible
NEWMAN_PROVIDER_MODEL=gpt-4.1-mini
NEWMAN_PROVIDER_ENDPOINT=https://api.openai.com/v1
NEWMAN_PROVIDER_API_KEY=your_api_key_here
NEWMAN_PROVIDER_TIMEOUT=60
NEWMAN_PROVIDER_MAX_TOKENS=4096
NEWMAN_PROVIDER_TEMPERATURE=0.2

# Runtime
NEWMAN_RUNTIME_MAX_TOOL_DEPTH=20
NEWMAN_RUNTIME_CONTEXT_COMPRESS_THRESHOLD=0.8
NEWMAN_RUNTIME_CONTEXT_CRITICAL_THRESHOLD=0.92

# Sandbox
NEWMAN_SANDBOX_ENABLED=false
NEWMAN_SANDBOX_TIMEOUT=30

# Channels
NEWMAN_CHANNELS_FEISHU_ENABLED=true
NEWMAN_CHANNELS_FEISHU_WEBHOOK_TOKEN=
NEWMAN_CHANNELS_WECOM_ENABLED=true
NEWMAN_CHANNELS_WECOM_WEBHOOK_TOKEN=
