# Newman runtime configuration
# Copy this file to `.env` and adjust values as needed.
# Recommended runtime:
#   conda activate newman
#   ./scripts/dev/start_postgres.sh
#   uvicorn backend.main:app --reload

# Server
NEWMAN_SERVER_HOST=0.0.0.0
NEWMAN_SERVER_PORT=8000

# Models
NEWMAN_MODELS_PRIMARY_TYPE=openai_compatible
NEWMAN_MODELS_PRIMARY_MODEL=gpt-4.1-mini
NEWMAN_MODELS_PRIMARY_ENDPOINT=https://api.openai.com/v1
NEWMAN_MODELS_PRIMARY_API_KEY=your_api_key_here
NEWMAN_MODELS_PRIMARY_CONTEXT_WINDOW=100000
NEWMAN_MODELS_PRIMARY_TIMEOUT=60
NEWMAN_MODELS_PRIMARY_MAX_TOKENS=4096
NEWMAN_MODELS_PRIMARY_TEMPERATURE=0.2

NEWMAN_MODELS_MULTIMODAL_TYPE=openai_compatible
NEWMAN_MODELS_MULTIMODAL_MODEL=gpt-4.1
NEWMAN_MODELS_MULTIMODAL_ENDPOINT=https://api.openai.com/v1
NEWMAN_MODELS_MULTIMODAL_API_KEY=your_api_key_here
NEWMAN_MODELS_MULTIMODAL_CONTEXT_WINDOW=32000

NEWMAN_MODELS_EMBEDDING_TYPE=openai_compatible
NEWMAN_MODELS_EMBEDDING_MODEL=text-embedding-3-large
NEWMAN_MODELS_EMBEDDING_ENDPOINT=https://api.openai.com/v1
NEWMAN_MODELS_EMBEDDING_API_KEY=your_api_key_here
NEWMAN_MODELS_EMBEDDING_DIMENSION=4096

NEWMAN_MODELS_RERANKER_TYPE=openai_compatible
NEWMAN_MODELS_RERANKER_MODEL=bge-reranker-v2-m3
NEWMAN_MODELS_RERANKER_ENDPOINT=http://localhost:8001/v1
NEWMAN_MODELS_RERANKER_API_KEY=
NEWMAN_MODELS_RERANKER_CONTEXT_WINDOW=32000

# Runtime
NEWMAN_RUNTIME_MAX_TOOL_DEPTH=20
NEWMAN_RUNTIME_CONTEXT_COMPRESS_THRESHOLD=0.8
NEWMAN_RUNTIME_CONTEXT_CRITICAL_THRESHOLD=0.92

# RAG
# Metadata and chunk mappings go to PostgreSQL.
# Vector index goes to Chroma persistent storage.
NEWMAN_RAG_POSTGRES_DSN=postgresql://postgres@127.0.0.1:54329/newman
NEWMAN_RAG_CHROMA_COLLECTION=knowledge_chunks
NEWMAN_PATHS_CHROMA_DIR=backend_data/chroma

# Sandbox
NEWMAN_SANDBOX_ENABLED=false
NEWMAN_SANDBOX_TIMEOUT=30

# Channels
NEWMAN_CHANNELS_FEISHU_ENABLED=true
NEWMAN_CHANNELS_FEISHU_WEBHOOK_TOKEN=
NEWMAN_CHANNELS_WECOM_ENABLED=true
NEWMAN_CHANNELS_WECOM_WEBHOOK_TOKEN=
